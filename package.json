{
  "name": "@dreki-gg/pi-slack",
  "version": "0.5.0",
  "description": "Slack read tools for pi \u2014 messages, threads, channels, search, and file/image downloads with Effect-powered client",
  "keywords": [
    "pi-package",
    "pi",
    "slack",
    "messages",
    "images"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-slack.git"
  },
  "type": "module",
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint extensions test",
    "format": "oxfmt --write extensions test",
    "format:check": "oxfmt --check extensions test"
  },
  "pi": {
    "extensions": [
      "./extensions/slack"
    ]
  },
  "dependencies": {
    "effect": "^3.21.4",
    "@effect/platform": "^0.96.2"
  },
  "devDependencies": {
    "@types/node": "26",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "typebox": "^1.3.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
